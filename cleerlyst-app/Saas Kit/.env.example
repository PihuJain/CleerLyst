# =============================================================================
# BEST SAAS KIT V2 - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# =============================================================================
# SITE CONFIGURATION
# =============================================================================
# Your site URL (use http://localhost:3000 for development)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Best SAAS Kit V2

# Development environment
NODE_ENV=development

# =============================================================================
# NEXTAUTH.JS CONFIGURATION
# =============================================================================
# NextAuth URL (should match your site URL)
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret (generate a random string)
# You can generate one at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-nextauth-secret-here

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Go to Credentials > Create Credentials > OAuth 2.0 Client IDs
# 5. Set authorized redirect URIs to: http://localhost:3000/api/auth/callback/google

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# DATABASE CONFIGURATION (NEON)
# =============================================================================
# Get this from Neon.tech:
# 1. Sign up at https://neon.tech/
# 2. Create a new project
# 3. Copy the connection string from your dashboard
# Format: postgresql://username:password@host/database?sslmode=require

DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# =============================================================================
# EMAIL CONFIGURATION (RESEND)
# =============================================================================
# Get this from Resend:
# 1. Sign up at https://resend.com/
# 2. Go to API Keys section
# 3. Create a new API key
# 4. Add your domain for sending emails

RESEND_API_KEY=your-resend-api-key

# Email settings
FROM_EMAIL=onboarding@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# =============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATIONS
# =============================================================================

# Admin email addresses (comma-separated)
# Users with these emails will have admin access
ADMIN_EMAILS=admin@yourdomain.com,admin2@yourdomain.com

# Analytics (if you plan to add analytics)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# POSTHOG_KEY=your-posthog-key

# File storage (if you plan to add file uploads)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Error tracking (if you plan to add error monitoring)
# SENTRY_DSN=your-sentry-dsn
